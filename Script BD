-- 1. Creación de la Base de Datos (Ajusta el nombre si tu profesor os pide otro)
CREATE DATABASE IF NOT EXISTS academia_db;
USE academia_db;

-- 2. Limpieza de tablas previas por si acaso repites la ejecución
DROP TABLE IF EXISTS curso;
DROP TABLE IF EXISTS usuario;

-- 3. Creación de la tabla de Usuarios (para el Login y los Roles)
CREATE TABLE usuario (
    id_usuario INT AUTO_INCREMENT PRIMARY KEY,
    username VARCHAR(50) NOT NULL UNIQUE,
    password VARCHAR(50) NOT NULL,
    rol VARCHAR(20) NOT NULL -- 'Admin' o 'User'
);

-- 4. Creación de la tabla de Cursos (Mapeada exactamente con tu MVC)
CREATE TABLE curso (
    id_curso INT AUTO_INCREMENT PRIMARY KEY,
    nombre VARCHAR(100) NOT NULL,
    horas INT NOT NULL,
    precio DECIMAL(10,2) NOT NULL,
    tipo VARCHAR(20) NOT NULL, -- 'Presencial' u 'Online'
    descripcion TEXT,
    url_imagen VARCHAR(255)
);

